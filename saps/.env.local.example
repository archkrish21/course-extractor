# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Drizzle direct connection for migrations + worker)
DATABASE_URL=

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Claude API
ANTHROPIC_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@contact.planwithgenie.com

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Google Sign-In (Google Identity Services / ID-token flow)
# OAuth 2.0 Web Client ID from Google Cloud Console.
# Configure Authorized JavaScript origins (e.g. http://localhost:3000,
# https://planwithgenie.com) — no redirect URIs needed for GIS.
# Also add this Client ID to Supabase → Auth → Providers → Google →
# "Authorized Client IDs" so signInWithIdToken accepts it.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# hCaptcha (optional — widget renders only when set)
# Get a free Site Key at https://dashboard.hcaptcha.com/sites
# Set this + the Secret Key in Supabase → Auth → Attack Protection
# to enable CAPTCHA on signup + login in prod. Leave unset in dev.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Support link (v1 only). Set to Ko-fi/BMAC URL to show "Support SAPS" in footers.
# Leave unset to hide. Unset this when subscription tiers launch.
NEXT_PUBLIC_SUPPORT_URL=
